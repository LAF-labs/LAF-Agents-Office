# Supabase hosted control plane.
# Copy this file to .env.local for local Vercel/API development.
# Replace <your-project-ref> with your own Supabase project ref.
# See docs/HOSTED-PRODUCT-BOUNDARY.md for setup.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=

# Server-only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Public host used when generating absolute URLs (e.g. invite links).
# Required in production to prevent Host-header injection.
LAF_OFFICE_PUBLIC_HOST=

# Comma-separated CORS origin allowlist (e.g. "https://app.example.com").
# Leave empty if the API is served same-origin via Vercel rewrites.
LAF_OFFICE_ALLOWED_ORIGINS=
